rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Custom claims are expected to be set by backend admin tooling.
    function role() {
      return isSignedIn() && request.auth.token.role is string ? request.auth.token.role : "";
    }

    function isAdmin() {
      return role() == "admin";
    }

    function isReviewer() {
      return role() == "reviewer" || isAdmin();
    }

    function isDoctor() {
      return role() == "doctor" || isAdmin();
    }

    function isPatientOrCaregiver(uid) {
      return isOwner(uid) || role() == "caregiver" || isAdmin();
    }

    // Default deny-all fallback.
    match /{document=**} {
      allow read, write: if false;
    }

    // User root profile
    match /users/{uid} {
      allow read, write: if isPatientOrCaregiver(uid);

      // Strict user-owned subcollections.
      match /medications/{id} {
        allow read, write: if isPatientOrCaregiver(uid);
      }
      match /verdicts/{id} {
        allow read, write: if isPatientOrCaregiver(uid);
      }
      match /reminders/{id} {
        allow read, write: if isPatientOrCaregiver(uid);
      }
      match /reminder_logs/{id} {
        allow read, write: if isPatientOrCaregiver(uid);
      }
      match /shares/{id} {
        allow read, write: if isPatientOrCaregiver(uid);
      }
      match /adverseEvents/{id} {
        allow read, write: if isPatientOrCaregiver(uid);
      }
      match /adr_reports/{id} {
        allow read, write: if isPatientOrCaregiver(uid);
      }
      match /fcm_tokens/{id} {
        allow read, write: if isPatientOrCaregiver(uid);
      }
      match /profiles/{id} {
        allow read, write: if isPatientOrCaregiver(uid);
      }

      // ABDM linkage + consent artifacts (PRD sections 11/18)
      match /abdm_consents/{id} {
        allow read, write: if isPatientOrCaregiver(uid) || isDoctor() || isReviewer();
      }
      match /abha_links/{id} {
        allow read, write: if isPatientOrCaregiver(uid) || isAdmin();
      }
    }

    // Admin / clinical review collections.
    match /aiReviewQueue/{id} {
      allow read: if isReviewer();
      allow create: if isSignedIn();
      allow update: if isReviewer();
      allow delete: if isAdmin();
    }

    match /interaction_flags/{id} {
      allow create: if isSignedIn();
      allow read: if isReviewer();
      allow update, delete: if isReviewer();
    }

    match /interactions/{id} {
      allow read: if isSignedIn();
      allow write: if isReviewer();
    }

    match /doctor_snapshots/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isDoctor() || isReviewer() || isAdmin();
      allow delete: if isAdmin();
    }

    match /adr_reports/{id} {
      allow read: if isReviewer();
      allow create: if isSignedIn();
      allow update, delete: if isReviewer();
    }

    match /content/{id} {
      allow read: if isSignedIn();
      allow write: if isReviewer();
    }

    match /campaigns/{id} {
      allow read: if isReviewer();
      allow write: if isReviewer();
    }

    match /settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /audits/{id} {
      allow create: if isSignedIn();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
  }
}
